  "dependencies": {
    "chalk": "^5.6.2",
    "openai": "^6.35.0",
    "puppeteer": "^24.42.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
