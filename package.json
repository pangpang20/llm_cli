{
  "name": "llm_cli",
  "version": "0.1.0",
  "description": "CLI agent tool - terminal-based AI assistant with file, shell, and browser tools",
  "main": "dist/index.js",
  "bin": {
    "llmcli": "./bin/llmcli"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
